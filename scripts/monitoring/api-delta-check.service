[Unit]
Description=Daily API-costs delta anomaly check (invoiced vs booked)
Documentation=file:///home/deploy/projects/ai-aggregator-lobechat/scripts/monitoring/check-api-delta.sh
After=docker.service
Wants=docker.service

[Service]
Type=oneshot
User=deploy
Group=deploy
# `docker exec lobe-postgres ...` needs access to the docker socket.
# The deploy user is already in the `docker` group on this VPS.
ExecStart=/usr/bin/env bash /home/deploy/projects/ai-aggregator-lobechat/scripts/monitoring/check-api-delta.sh
StandardOutput=append:/home/deploy/.claude/logs/check-api-delta.log
StandardError=append:/home/deploy/.claude/logs/check-api-delta.log
TimeoutStartSec=300
